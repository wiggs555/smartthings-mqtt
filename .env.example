SMARTTHINGS_TOKEN=your-personal-access-token
MQTT_HOST=10.0.1.9
MQTT_PORT=1883
MQTT_USERNAME=smartthings_mqtt
MQTT_PASSWORD=your-secure-password
MQTT_TOPIC_PREFIX=smartthings/tv
MQTT_DISCOVERY_PREFIX=homeassistant
POLL_INTERVAL_SECONDS=15
DEVICE_RESCAN_INTERVAL_SECONDS=300
LOG_LEVEL=INFO
LOCAL_ENABLED=true
LOCAL_TOKEN_DIR=~/.smartthings-mqtt/tokens
DEVICES_CONFIG=config/devices.yaml
WOL_RETRIES=3
WOL_RETRY_INTERVAL_SECONDS=5
LOCAL_CONNECT_TIMEOUT_SECONDS=10
MQTT_CONNECT_TIMEOUT_SECONDS=30
MQTT_CONNECT_RETRY_SECONDS=5
